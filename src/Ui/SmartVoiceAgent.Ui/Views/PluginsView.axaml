<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SmartVoiceAgent.Ui.ViewModels.PageModels"
             xmlns:services="clr-namespace:SmartVoiceAgent.Ui.Services"
             xmlns:converters="clr-namespace:SmartVoiceAgent.Ui.Converters"
             x:Class="SmartVoiceAgent.Ui.Views.PluginsView"
             x:DataType="vm:PluginsViewModel">

    <UserControl.Resources>
        <services:WindowStateManager x:Key="WindowStateManager" />
        <converters:ResponsiveFontSizeConverter x:Key="ResponsiveFontSizeConverter" />
    </UserControl.Resources>

    <UserControl.Styles>
        <!-- Plugin Card Style -->
        <Style Selector="Border.PluginCard">
            <Setter Property="Background" Value="{DynamicResource CardBgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="MinHeight" Value="320"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.3"/>
                    <BrushTransition Property="Background" Duration="0:0:0.3"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Border.PluginCard:pointerover">
            <Setter Property="Background" Value="{DynamicResource CardBgHoverBrush}"/>
        </Style>

        <!-- Inactive Plugin Card -->
        <Style Selector="Border.PluginCardInactive">
            <Setter Property="Background" Value="{DynamicResource SurfaceBgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="MinHeight" Value="320"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.3"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Border.PluginCardInactive:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource BorderMutedBrush}"/>
        </Style>

        <!-- Add Plugin Card -->
        <Style Selector="Border.AddPluginCard">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="MinHeight" Value="220"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.3"/>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.3"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Border.AddPluginCard:pointerover">
            <Setter Property="Background" Value="{DynamicResource SurfaceBgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderMutedBrush}"/>
        </Style>

        <!-- Status Badge Active -->
        <Style Selector="Border.StatusActive">
            <Setter Property="Background" Value="{DynamicResource AccentGreenGlowBrush}"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>

        <!-- Status Badge Inactive -->
        <Style Selector="Border.StatusInactive">
            <Setter Property="Background" Value="{DynamicResource SurfaceBgBrush}"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>

        <Style Selector="Button.PluginActionButton">
            <Setter Property="Background" Value="{DynamicResource SurfaceBgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Opacity" Value="0.96"/>
        </Style>

        <Style Selector="Button.PluginActionButton:pointerover">
            <Setter Property="Background" Value="{DynamicResource CardBgHoverBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentCyanDimBrush}"/>
            <Setter Property="Opacity" Value="1"/>
        </Style>

        <Style Selector="Button.PluginActionButton Path">
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Stretch" Value="Uniform"/>
        </Style>

        <!-- Pulsing Dot Animation -->
        <Style Selector="Ellipse.PulsingDot">
            <Style.Animations>
                <Animation Duration="0:0:2" IterationCount="Infinite">
                    <KeyFrame KeyTime="0:0:0">
                        <Setter Property="Opacity" Value="1"/>
                    </KeyFrame>
                    <KeyFrame KeyTime="0:0:1">
                        <Setter Property="Opacity" Value="0.4"/>
                    </KeyFrame>
                    <KeyFrame KeyTime="0:0:2">
                        <Setter Property="Opacity" Value="1"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <Style Selector="Border.EvalSummary">
            <Setter Property="Background" Value="{DynamicResource SurfaceBgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14,12"/>
        </Style>

        <Style Selector="Border.EvalHealthy">
            <Setter Property="BorderBrush" Value="#4010B981"/>
        </Style>

        <Style Selector="Border.EvalUnhealthy">
            <Setter Property="BorderBrush" Value="#40F59E0B"/>
        </Style>

        <Style Selector="Border.ImportPanel">
            <Setter Property="Background" Value="{DynamicResource SurfaceBgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14,12"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <Grid RowDefinitions="Auto, Auto, Auto, Auto, *" Margin="0,20">

            <!-- Title Section -->
            <StackPanel Grid.Row="0" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,20,0,24">
                <TextBlock Text="{DynamicResource Lang.Plugins.Title}"
                           FontSize="{Binding Source={StaticResource WindowStateManager}, Path=WindowWidth, Converter={StaticResource ResponsiveFontSizeConverter}, ConverterParameter=48}"
                           LetterSpacing="16"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           FontWeight="Light"/>
                <TextBlock Text="{DynamicResource Lang.Plugins.Subtitle}"
                           Foreground="{DynamicResource AccentCyanBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"
                           FontSize="12"
                           FontFamily="Consolas"
                           LetterSpacing="2"/>
            </StackPanel>

            <Border Grid.Row="1"
                    Classes="EvalSummary"
                    Classes.EvalHealthy="{Binding IsSkillEvalHealthy}"
                    Classes.EvalUnhealthy="{Binding !IsSkillEvalHealthy}"
                    Margin="8,0,8,20"
                    MaxWidth="920"
                    HorizontalAlignment="Stretch">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                    <Ellipse Grid.Column="0"
                             Width="10"
                             Height="10"
                             Fill="{DynamicResource AccentCyanBrush}"
                             VerticalAlignment="Top"
                             Margin="0,4,0,0"
                             IsVisible="{Binding IsSkillEvalHealthy}"/>
                    <Ellipse Grid.Column="0"
                             Width="10"
                             Height="10"
                             Fill="{DynamicResource AccentOrangeBrush}"
                             VerticalAlignment="Top"
                             Margin="0,4,0,0"
                             IsVisible="{Binding !IsSkillEvalHealthy}"/>
                    <StackPanel Grid.Column="1" Spacing="4">
                        <TextBlock Text="{Binding SkillEvalStatus}"
                                   FontSize="12"
                                   FontFamily="Consolas"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding SkillEvalDetail}"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   TextWrapping="Wrap"/>
                        <ScrollViewer IsVisible="{Binding HasSkillEvalResults}"
                                      MaxHeight="132"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Margin="0,6,0,0">
                            <ItemsControl ItemsSource="{Binding SkillEvalResults}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="54,*,108"
                                              ColumnSpacing="8"
                                              Margin="0,2">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding StatusText}"
                                                       FontSize="10"
                                                       FontFamily="Consolas"
                                                       Foreground="{Binding StatusColor}"
                                                       TextWrapping="NoWrap"/>
                                            <StackPanel Grid.Column="1" Spacing="1">
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="10"
                                                           FontFamily="Consolas"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           TextWrapping="NoWrap"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding ExpectedActualText}"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           TextWrapping="NoWrap"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding DetailText}"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           TextWrapping="Wrap"
                                                           MaxLines="2"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding SkillId}"
                                                       FontSize="10"
                                                       FontFamily="Consolas"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                    <Button Grid.Column="2"
                            Command="{Binding RunSkillEvalCommand}"
                            ToolTip.Tip="Run smoke evals"
                            MinHeight="30"
                            Padding="12,0"
                            VerticalAlignment="Center">
                        <Path Data="M8,5V19L19,12L8,5Z"
                              Fill="{DynamicResource AccentCyanBrush}"
                              Width="13"
                              Height="13"
                              Stretch="Uniform"/>
                    </Button>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Classes="ImportPanel"
                    Margin="8,0,8,20"
                    MaxWidth="920"
                    HorizontalAlignment="Stretch">
                <Grid RowDefinitions="Auto,Auto" RowSpacing="8">
                    <Grid Grid.Row="0" ColumnDefinitions="150,*,Auto" ColumnSpacing="8">
                        <ComboBox Grid.Column="0"
                                  ItemsSource="{Binding ImportSources}"
                                  SelectedIndex="{Binding SelectedImportSourceIndex}"
                                  MinHeight="34"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding ImportLocation}"
                                 PlaceholderText="Folder path containing SKILL.md"
                                 MinHeight="34"/>
                        <Button Grid.Column="2"
                                Content="Import"
                                Command="{Binding ImportSkillCommand}"
                                MinHeight="34"
                                Padding="18,0"/>
                    </Grid>
                    <TextBlock Grid.Row="1"
                               Text="{Binding ImportStatus}"
                               FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}"
                               TextWrapping="Wrap"/>
                </Grid>
            </Border>

            <Border Grid.Row="3"
                    Classes="ImportPanel"
                    IsVisible="{Binding HasSelectedPlugin}"
                    Margin="8,0,8,20"
                    MaxWidth="920"
                    HorizontalAlignment="Stretch">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <StackPanel Grid.Column="0" Spacing="6">
                        <TextBlock Text="{Binding SelectedSkillTitle}"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding SelectedSkillId}"
                                   FontSize="11"
                                   FontFamily="Consolas"
                                   Foreground="{DynamicResource AccentCyanBrush}"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding SelectedSkillSource}"
                                   FontSize="10"
                                   FontFamily="Consolas"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis"/>
                        <WrapPanel>
                            <TextBlock Text="{Binding SelectedSkillExecutor}"
                                       FontSize="10"
                                       FontFamily="Consolas"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       Margin="0,0,14,0"/>
                            <TextBlock Text="{Binding SelectedSkillRisk}"
                                       FontSize="10"
                                       FontFamily="Consolas"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       Margin="0,0,14,0"/>
                            <TextBlock Text="{Binding SelectedSkillChecksum}"
                                       FontSize="10"
                                       FontFamily="Consolas"
                                       Foreground="{DynamicResource TextMutedBrush}"/>
                        </WrapPanel>
                        <TextBlock Text="{Binding SelectedSkillPermissions}"
                                   FontSize="10"
                                   FontFamily="Consolas"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding SelectedSkillLastRun}"
                                   FontSize="10"
                                   FontFamily="Consolas"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding SelectedSkillHealthMetrics}"
                                   FontSize="10"
                                   FontFamily="Consolas"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   TextWrapping="Wrap"/>
                        <StackPanel IsVisible="{Binding HasSelectedSkillExecutionHistory}"
                                    Spacing="3"
                                    Margin="0,4,0,0">
                            <TextBlock Text="Execution History"
                                       FontSize="10"
                                       FontFamily="Consolas"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <ItemsControl ItemsSource="{Binding SelectedSkillExecutionHistory}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="140,120,*"
                                              ColumnSpacing="8"
                                              Margin="0,1">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding TimestampText}"
                                                       FontSize="10"
                                                       FontFamily="Consolas"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       TextWrapping="NoWrap"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding StatusText}"
                                                       FontSize="10"
                                                       FontFamily="Consolas"
                                                       Foreground="{Binding StatusColor}"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding DetailText}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       TextWrapping="Wrap"
                                                       MaxLines="2"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                        <TextBlock Text="{Binding SelectedSkillPolicyGuardrail}"
                                   FontSize="10"
                                   FontFamily="Consolas"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"/>
                        <Grid ColumnDefinitions="170,*,Auto"
                              ColumnSpacing="8"
                              IsVisible="{Binding CanEditSelectedSkillPolicy}">
                            <TextBox Grid.Column="0"
                                     Text="{Binding PolicyOptionKeyInput, Mode=TwoWay}"
                                     PlaceholderText="policy key"
                                     MinHeight="32"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding PolicyOptionValueInput, Mode=TwoWay}"
                                     PlaceholderText="value"
                                     MinHeight="32"/>
                            <Button Grid.Column="2"
                                    Command="{Binding SaveRuntimePolicyOptionCommand}"
                                    ToolTip.Tip="Save runtime policy"
                                    MinHeight="32"
                                    Padding="10,0">
                                <Path Data="M9,16.2L4.8,12L3.4,13.4L9,19L21,7L19.6,5.6L9,16.2Z"
                                      Fill="{DynamicResource AccentCyanBrush}"
                                      Width="13"
                                      Height="13"
                                      Stretch="Uniform"/>
                            </Button>
                        </Grid>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Command="{Binding SelectedPlugin.TestSkillCommand}"
                            IsVisible="{Binding SelectedPlugin.CanTestSkill}"
                            ToolTip.Tip="Test skill"
                            MinHeight="32"
                            Padding="12,0"
                            VerticalAlignment="Top">
                        <Path Data="M8,5V19L19,12L8,5Z"
                              Fill="{DynamicResource AccentCyanBrush}"
                              Width="13"
                              Height="13"
                              Stretch="Uniform"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Plugins Grid - Responsive Columns -->
            <ItemsControl Grid.Row="4" ItemsSource="{Binding Plugins}" Margin="0,0,0,20">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="{Binding Source={StaticResource WindowStateManager}, Path=GridColumns}"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Classes.PluginCard="{Binding IsActive}"
                                Classes.PluginCardInactive="{Binding !IsActive}"
                                Margin="8">
                            <Grid RowDefinitions="Auto, *, Auto">
                                <!-- Icon with Glow -->
                                <Grid Grid.Row="0"
                                      Classes="PluginIconBadge"
                                      Width="40" Height="40"
                                      HorizontalAlignment="Left"
                                      Margin="0,0,0,24">
                                    <Ellipse Width="40" Height="40" Fill="{Binding GlowColor}">
                                        <Ellipse.Effect>
                                            <BlurEffect Radius="8"/>
                                        </Ellipse.Effect>
                                    </Ellipse>
                                    <Ellipse Width="40" Height="40" Fill="{Binding GlowColor}"/>
                                    <Ellipse Classes="PulsingDot"
                                             Width="16" Height="16"
                                             Fill="{Binding IconColor}"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             IsVisible="{Binding IsActive}"/>
                                    <Ellipse Width="16" Height="16"
                                             Fill="{DynamicResource TextMutedBrush}"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             IsVisible="{Binding !IsActive}"/>
                                </Grid>

                                <!-- Content -->
                                <StackPanel Grid.Row="1" VerticalAlignment="Stretch">
                                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   LetterSpacing="1"
                                                   Foreground="{Binding TextColor}"
                                                   TextWrapping="Wrap"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxLines="2"/>
                                        <Border Classes.StatusActive="{Binding IsActive}"
                                                Classes.StatusInactive="{Binding !IsActive}"
                                                Grid.Column="1"
                                                VerticalAlignment="Top"
                                                MaxWidth="82"
                                                Margin="8,0,0,0">
                                            <TextBlock Text="{Binding Status}"
                                                       FontSize="9"
                                                       FontFamily="Consolas"
                                                       Foreground="{Binding StatusColor}"
                                                       VerticalAlignment="Center"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Border>
                                    </Grid>
                                    <TextBlock Text="{Binding SkillId}"
                                               FontSize="10"
                                               Foreground="{DynamicResource AccentCyanBrush}"
                                               FontFamily="Consolas"
                                               TextWrapping="NoWrap"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,0,0,6"/>
                                    <TextBlock Text="{Binding Source}"
                                               FontSize="10"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               FontFamily="Consolas"
                                               TextWrapping="NoWrap"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding RequiredPermissionsText}"
                                               FontSize="10"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               FontFamily="Consolas"
                                               TextWrapping="NoWrap"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding GrantedPermissionsText}"
                                               FontSize="10"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               FontFamily="Consolas"
                                               TextWrapping="NoWrap"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding MissingPermissionsText}"
                                               FontSize="10"
                                               Foreground="{DynamicResource AccentErrorBrush}"
                                               FontFamily="Consolas"
                                               TextWrapping="NoWrap"
                                               TextTrimming="CharacterEllipsis"
                                               IsVisible="{Binding HasMissingPermissions}"
                                               Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding Description}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               TextWrapping="Wrap"
                                               LineHeight="18"
                                               MaxLines="2"/>
                                    <TextBlock Text="{Binding HealthDetail}"
                                               FontSize="10"
                                               Foreground="{Binding StatusColor}"
                                               TextWrapping="Wrap"
                                               LineHeight="16"
                                               MaxLines="2"
                                               Margin="0,8,0,0"/>
                                    <StackPanel IsVisible="{Binding HasLastRun}"
                                                Spacing="3"
                                                Margin="0,8,0,0">
                                        <TextBlock Text="{Binding LastRunStatus}"
                                                   FontSize="10"
                                                   FontFamily="Consolas"
                                                   Foreground="{Binding LastRunColor}"
                                                   TextWrapping="NoWrap"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding LastRunDetail}"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   TextWrapping="Wrap"
                                                   MaxLines="2"/>
                                    </StackPanel>
                                    <StackPanel IsVisible="{Binding HasHealthMetrics}"
                                                Spacing="3"
                                                Margin="0,8,0,0">
                                        <TextBlock Text="{Binding HealthMetricsText}"
                                                   FontSize="10"
                                                   FontFamily="Consolas"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap"
                                                   MaxLines="2"/>
                                        <TextBlock Text="{Binding FailureMetricsText}"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource AccentErrorBrush}"
                                                   TextWrapping="Wrap"
                                                   MaxLines="2"
                                                   IsVisible="{Binding HasFailureMetrics}"/>
                                    </StackPanel>
                                    <Border IsVisible="{Binding HasEvalResult}"
                                            Background="{DynamicResource SurfaceBgBrush}"
                                            BorderBrush="{DynamicResource BorderSubtleBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="8,6"
                                            Margin="0,8,0,0">
                                        <StackPanel Spacing="3">
                                            <TextBlock Text="{Binding LastEvalStatus}"
                                                       FontSize="10"
                                                       FontFamily="Consolas"
                                                       Foreground="{DynamicResource AccentCyanBrush}"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding LastEvalDetail}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       TextWrapping="Wrap"
                                                       MaxLines="2"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                                <StackPanel Grid.Row="2"
                                            Classes="PluginActionBar"
                                            Orientation="Horizontal"
                                            Spacing="8"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Bottom"
                                            Margin="0,14,0,0">
                                    <Button Classes="IconButton PluginActionButton"
                                            Width="30" Height="30"
                                            Padding="0"
                                            Cursor="Hand"
                                            ToolTip.Tip="Details"
                                            Command="{Binding SelectCommand}">
                                        <Path Data="M11,17H13V11H11V17M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M11,7V9H13V7H11Z"
                                              Fill="{DynamicResource AccentCyanBrush}"
                                              Width="16" Height="16"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Stretch="Uniform"/>
                                    </Button>
                                    <Button Classes="IconButton PluginActionButton"
                                            Width="30" Height="30"
                                            Padding="0"
                                            Cursor="Hand"
                                            ToolTip.Tip="Test Skill"
                                            IsVisible="{Binding CanTestSkill}"
                                            Command="{Binding TestSkillCommand}">
                                        <Path Data="M8,5V19L19,12L8,5Z"
                                              Fill="{DynamicResource AccentCyanBrush}"
                                              Width="16" Height="16"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Stretch="Uniform"/>
                                    </Button>
                                    <Button Classes="IconButton PluginActionButton"
                                            Width="30" Height="30"
                                            Padding="0"
                                            Cursor="Hand"
                                            ToolTip.Tip="Approve Review"
                                            IsVisible="{Binding CanApproveReview}"
                                            Command="{Binding ApproveReviewCommand}">
                                        <Path Data="M9,16.17L4.83,12L3.41,13.41L9,19L21,7L19.59,5.59L9,16.17Z"
                                              Fill="{DynamicResource AccentCyanBrush}"
                                              Width="16" Height="16"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Stretch="Uniform"/>
                                    </Button>
                                    <Button Classes="IconButton PluginActionButton"
                                            Width="30" Height="30"
                                            Padding="0"
                                            Cursor="Hand"
                                            ToolTip.Tip="Enable"
                                            IsVisible="{Binding CanEnable}"
                                            Command="{Binding EnableCommand}">
                                        <Path Data="M8,5V19L19,12L8,5Z"
                                              Fill="{DynamicResource AccentGreenBrush}"
                                              Width="16" Height="16"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Stretch="Uniform"/>
                                    </Button>
                                    <Button Classes="IconButton PluginActionButton"
                                            Width="30" Height="30"
                                            Padding="0"
                                            Cursor="Hand"
                                            ToolTip.Tip="Grant Permissions"
                                            IsVisible="{Binding CanGrantPermissions}"
                                            Command="{Binding GrantPermissionsCommand}">
                                        <Path Data="M12,17A2,2 0 0,0 14,15A2,2 0 0,0 12,13A2,2 0 0,0 10,15A2,2 0 0,0 12,17M18,8H17V6A5,5 0 0,0 7,6V8H6A2,2 0 0,0 4,10V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V10A2,2 0 0,0 18,8M9,8V6A3,3 0 0,1 15,6V8H9Z"
                                              Fill="{DynamicResource AccentCyanBrush}"
                                              Width="16" Height="16"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Stretch="Uniform"/>
                                    </Button>
                                    <Button Classes="IconButton PluginActionButton"
                                            Width="30" Height="30"
                                            Padding="0"
                                            Cursor="Hand"
                                            ToolTip.Tip="Disable"
                                            IsVisible="{Binding CanDisable}"
                                            Command="{Binding DisableCommand}">
                                        <Path Data="M6,6H18V18H6V6Z"
                                              Fill="{DynamicResource TextMutedBrush}"
                                              Width="16" Height="16"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Stretch="Uniform"/>
                                    </Button>
                                    <Button Classes="IconButton PluginActionButton"
                                            Width="30" Height="30"
                                            Padding="0"
                                            Cursor="Hand"
                                            ToolTip.Tip="Revoke Permissions"
                                            IsVisible="{Binding CanRevokePermissions}"
                                            Command="{Binding RevokePermissionsCommand}">
                                        <Path Data="M18.3,5.71L12,12L18.3,18.29L16.89,19.7L10.59,13.41L4.29,19.7L2.88,18.29L9.17,12L2.88,5.71L4.29,4.3L10.59,10.59L16.89,4.3L18.3,5.71Z"
                                              Fill="{DynamicResource AccentErrorBrush}"
                                              Width="16" Height="16"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Stretch="Uniform"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </ScrollViewer>
</UserControl>
