<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SmartVoiceAgent.Ui.ViewModels.PageModels"
             xmlns:services="clr-namespace:SmartVoiceAgent.Ui.Services"
             xmlns:converters="clr-namespace:SmartVoiceAgent.Ui.Converters"
             x:Class="SmartVoiceAgent.Ui.Views.PluginsView"
             x:DataType="vm:PluginsViewModel">

    <UserControl.Resources>
        <services:WindowStateManager x:Key="WindowStateManager" />
        <converters:ResponsiveFontSizeConverter x:Key="ResponsiveFontSizeConverter" />
    </UserControl.Resources>

    <UserControl.Styles>
        <!-- Plugin Card Style -->
        <Style Selector="Border.PluginCard">
            <Setter Property="Background" Value="{DynamicResource CardBgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="MinHeight" Value="220"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.3"/>
                    <BrushTransition Property="Background" Duration="0:0:0.3"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Border.PluginCard:pointerover">
            <Setter Property="Background" Value="{DynamicResource CardBgHoverBrush}"/>
        </Style>

        <!-- Inactive Plugin Card -->
        <Style Selector="Border.PluginCardInactive">
            <Setter Property="Background" Value="{DynamicResource SurfaceBgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="MinHeight" Value="220"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.3"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Border.PluginCardInactive:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource BorderMutedBrush}"/>
        </Style>

        <!-- Add Plugin Card -->
        <Style Selector="Border.AddPluginCard">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="MinHeight" Value="220"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.3"/>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.3"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Border.AddPluginCard:pointerover">
            <Setter Property="Background" Value="{DynamicResource SurfaceBgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderMutedBrush}"/>
        </Style>

        <!-- Status Badge Active -->
        <Style Selector="Border.StatusActive">
            <Setter Property="Background" Value="{DynamicResource AccentGreenGlowBrush}"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>

        <!-- Status Badge Inactive -->
        <Style Selector="Border.StatusInactive">
            <Setter Property="Background" Value="{DynamicResource SurfaceBgBrush}"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>

        <!-- Pulsing Dot Animation -->
        <Style Selector="Ellipse.PulsingDot">
            <Style.Animations>
                <Animation Duration="0:0:2" IterationCount="Infinite">
                    <KeyFrame KeyTime="0:0:0">
                        <Setter Property="Opacity" Value="1"/>
                    </KeyFrame>
                    <KeyFrame KeyTime="0:0:1">
                        <Setter Property="Opacity" Value="0.4"/>
                    </KeyFrame>
                    <KeyFrame KeyTime="0:0:2">
                        <Setter Property="Opacity" Value="1"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <Style Selector="Border.EvalSummary">
            <Setter Property="Background" Value="{DynamicResource SurfaceBgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14,12"/>
        </Style>

        <Style Selector="Border.EvalHealthy">
            <Setter Property="BorderBrush" Value="#4010B981"/>
        </Style>

        <Style Selector="Border.EvalUnhealthy">
            <Setter Property="BorderBrush" Value="#40F59E0B"/>
        </Style>

        <Style Selector="Border.ImportPanel">
            <Setter Property="Background" Value="{DynamicResource SurfaceBgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14,12"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <Grid RowDefinitions="Auto, Auto, Auto, *" Margin="0,20">

            <!-- Title Section -->
            <StackPanel Grid.Row="0" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,20,0,24">
                <TextBlock Text="{DynamicResource Lang.Plugins.Title}"
                           FontSize="{Binding Source={StaticResource WindowStateManager}, Path=WindowWidth, Converter={StaticResource ResponsiveFontSizeConverter}, ConverterParameter=48}"
                           LetterSpacing="16"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           FontWeight="Light"/>
                <TextBlock Text="{DynamicResource Lang.Plugins.Subtitle}"
                           Foreground="{DynamicResource AccentCyanBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"
                           FontSize="12"
                           FontFamily="Consolas"
                           LetterSpacing="2"/>
            </StackPanel>

            <Border Grid.Row="1"
                    Classes="EvalSummary"
                    Classes.EvalHealthy="{Binding IsSkillEvalHealthy}"
                    Classes.EvalUnhealthy="{Binding !IsSkillEvalHealthy}"
                    Margin="8,0,8,20"
                    MaxWidth="920"
                    HorizontalAlignment="Stretch">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                    <Ellipse Grid.Column="0"
                             Width="10"
                             Height="10"
                             Fill="{DynamicResource AccentCyanBrush}"
                             VerticalAlignment="Top"
                             Margin="0,4,0,0"
                             IsVisible="{Binding IsSkillEvalHealthy}"/>
                    <Ellipse Grid.Column="0"
                             Width="10"
                             Height="10"
                             Fill="#F59E0B"
                             VerticalAlignment="Top"
                             Margin="0,4,0,0"
                             IsVisible="{Binding !IsSkillEvalHealthy}"/>
                    <StackPanel Grid.Column="1" Spacing="4">
                        <TextBlock Text="{Binding SkillEvalStatus}"
                                   FontSize="12"
                                   FontFamily="Consolas"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding SkillEvalDetail}"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Classes="ImportPanel"
                    Margin="8,0,8,20"
                    MaxWidth="920"
                    HorizontalAlignment="Stretch">
                <Grid RowDefinitions="Auto,Auto" RowSpacing="8">
                    <Grid Grid.Row="0" ColumnDefinitions="150,*,Auto" ColumnSpacing="8">
                        <ComboBox Grid.Column="0"
                                  ItemsSource="{Binding ImportSources}"
                                  SelectedIndex="{Binding SelectedImportSourceIndex}"
                                  MinHeight="34"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding ImportLocation}"
                                 PlaceholderText="Folder path containing SKILL.md"
                                 MinHeight="34"/>
                        <Button Grid.Column="2"
                                Content="Import"
                                Command="{Binding ImportSkillCommand}"
                                MinHeight="34"
                                Padding="18,0"/>
                    </Grid>
                    <TextBlock Grid.Row="1"
                               Text="{Binding ImportStatus}"
                               FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}"
                               TextWrapping="Wrap"/>
                </Grid>
            </Border>

            <!-- Plugins Grid - Responsive Columns -->
            <ItemsControl Grid.Row="3" ItemsSource="{Binding Plugins}" Margin="0,0,0,20">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="{Binding Source={StaticResource WindowStateManager}, Path=GridColumns}"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Classes.PluginCard="{Binding IsActive}"
                                Classes.PluginCardInactive="{Binding !IsActive}"
                                Margin="8">
                            <Grid RowDefinitions="Auto, *, Auto">
                                <!-- Icon with Glow -->
                                <Grid Grid.Row="0" Width="40" Height="40" HorizontalAlignment="Left" Margin="0,0,0,24">
                                    <Ellipse Width="40" Height="40" Fill="{Binding GlowColor}">
                                        <Ellipse.Effect>
                                            <BlurEffect Radius="8"/>
                                        </Ellipse.Effect>
                                    </Ellipse>
                                    <Ellipse Width="40" Height="40" Fill="{Binding GlowColor}"/>
                                    <Ellipse Classes="PulsingDot"
                                             Width="16" Height="16"
                                             Fill="{Binding IconColor}"
                                             IsVisible="{Binding IsActive}"/>
                                    <Ellipse Width="16" Height="16"
                                             Fill="{DynamicResource TextMutedBrush}"
                                             IsVisible="{Binding !IsActive}"/>
                                </Grid>

                                <!-- Content -->
                                <StackPanel Grid.Row="2" VerticalAlignment="Bottom">
                                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   LetterSpacing="1"
                                                   Foreground="{Binding TextColor}"
                                                   TextWrapping="Wrap"
                                                   MaxLines="2"/>
                                        <Border Classes.StatusActive="{Binding IsActive}"
                                                Classes.StatusInactive="{Binding !IsActive}"
                                                Grid.Column="1"
                                                VerticalAlignment="Top"
                                                Margin="8,0,0,0">
                                            <TextBlock Text="{Binding Status}"
                                                       FontSize="9"
                                                       FontFamily="Consolas"
                                                       Foreground="{Binding StatusColor}"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                    <TextBlock Text="{Binding SkillId}"
                                               FontSize="10"
                                               Foreground="{DynamicResource AccentCyanBrush}"
                                               FontFamily="Consolas"
                                               TextWrapping="NoWrap"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,0,0,6"/>
                                    <TextBlock Text="{Binding Source}"
                                               FontSize="10"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               FontFamily="Consolas"
                                               TextWrapping="NoWrap"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding Description}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextMutedBrush}"
                                               TextWrapping="Wrap"
                                               LineHeight="18"
                                               MaxLines="2"/>
                                    <TextBlock Text="{Binding HealthDetail}"
                                               FontSize="10"
                                               Foreground="{Binding StatusColor}"
                                               TextWrapping="Wrap"
                                               LineHeight="16"
                                               MaxLines="2"
                                               Margin="0,8,0,0"/>
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="6"
                                                Margin="0,12,0,0">
                                        <Button Width="28" Height="28"
                                                Background="Transparent"
                                                BorderBrush="{DynamicResource AccentCyanDimBrush}"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Padding="0"
                                                Cursor="Hand"
                                                ToolTip.Tip="Approve Review"
                                                IsVisible="{Binding CanApproveReview}"
                                                Command="{Binding ApproveReviewCommand}">
                                            <Path Data="M9,16.17L4.83,12L3.41,13.41L9,19L21,7L19.59,5.59L9,16.17Z"
                                                  Fill="{DynamicResource AccentCyanBrush}"
                                                  Width="15" Height="15"
                                                  Stretch="Uniform"/>
                                        </Button>
                                        <Button Width="28" Height="28"
                                                Background="Transparent"
                                                BorderBrush="{DynamicResource AccentGreenBrush}"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Padding="0"
                                                Cursor="Hand"
                                                ToolTip.Tip="Enable"
                                                IsVisible="{Binding CanEnable}"
                                                Command="{Binding EnableCommand}">
                                            <Path Data="M8,5V19L19,12L8,5Z"
                                                  Fill="{DynamicResource AccentGreenBrush}"
                                                  Width="14" Height="14"
                                                  Stretch="Uniform"/>
                                        </Button>
                                        <Button Width="28" Height="28"
                                                Background="Transparent"
                                                BorderBrush="{DynamicResource TextMutedBrush}"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Padding="0"
                                                Cursor="Hand"
                                                ToolTip.Tip="Disable"
                                                IsVisible="{Binding CanDisable}"
                                                Command="{Binding DisableCommand}">
                                            <Path Data="M6,19H10V5H6V19M14,5V19H18V5H14Z"
                                                  Fill="{DynamicResource TextMutedBrush}"
                                                  Width="14" Height="14"
                                                  Stretch="Uniform"/>
                                        </Button>
                                        <Button Width="28" Height="28"
                                                Background="Transparent"
                                                BorderBrush="{DynamicResource AccentErrorBrush}"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Padding="0"
                                                Cursor="Hand"
                                                ToolTip.Tip="Revoke Permissions"
                                                IsVisible="{Binding CanRevokePermissions}"
                                                Command="{Binding RevokePermissionsCommand}">
                                            <Path Data="M12,2L4,5V11C4,16.55 7.84,21.74 12,23C16.16,21.74 20,16.55 20,11V5L12,2M12,4.18L18,6.43V11C18,15.55 15.11,19.82 12,20.88C8.89,19.82 6,15.55 6,11V6.43L12,4.18M8.46,8.88L7.05,10.29L10.76,14L7.05,17.71L8.46,19.12L12.17,15.41L15.88,19.12L17.29,17.71L13.58,14L17.29,10.29L15.88,8.88L12.17,12.59L8.46,8.88Z"
                                                  Fill="{DynamicResource AccentErrorBrush}"
                                                  Width="15" Height="15"
                                                  Stretch="Uniform"/>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </ScrollViewer>
</UserControl>
