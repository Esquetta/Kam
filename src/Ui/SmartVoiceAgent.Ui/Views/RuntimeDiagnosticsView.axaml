<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SmartVoiceAgent.Ui.ViewModels.PageModels"
             x:Class="SmartVoiceAgent.Ui.Views.RuntimeDiagnosticsView"
             x:DataType="vm:RuntimeDiagnosticsViewModel">

    <UserControl.Styles>
        <Style Selector="Border.ReadinessCard">
            <Setter Property="Background" Value="{DynamicResource CardBgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="MinHeight" Value="108"/>
        </Style>

        <Style Selector="Border.DiagnosticPanel">
            <Setter Property="Background" Value="{DynamicResource CardBgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="18"/>
        </Style>

        <Style Selector="Border.DiagnosticRow">
            <Setter Property="Background" Value="{DynamicResource SurfaceBgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style Selector="Border.Ready">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentGreenBrush}"/>
        </Style>

        <Style Selector="Border.Warning">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentOrangeBrush}"/>
        </Style>

        <Style Selector="Border.Blocked">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentErrorBrush}"/>
        </Style>

        <Style Selector="Ellipse.StatusDot">
            <Setter Property="Width" Value="9"/>
            <Setter Property="Height" Value="9"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style Selector="Ellipse.ReadyDot">
            <Setter Property="Fill" Value="{DynamicResource AccentGreenBrush}"/>
        </Style>

        <Style Selector="Ellipse.WarningDot">
            <Setter Property="Fill" Value="{DynamicResource AccentOrangeBrush}"/>
        </Style>

        <Style Selector="Ellipse.BlockedDot">
            <Setter Property="Fill" Value="{DynamicResource AccentErrorBrush}"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <Grid RowDefinitions="Auto, Auto, Auto, Auto, *"
              RowSpacing="16"
              Margin="0,18,0,24"
              MaxWidth="980"
              HorizontalAlignment="Stretch">

            <Grid Grid.Row="0" ColumnDefinitions="*, Auto" ColumnSpacing="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="RUNTIME DIAGNOSTICS"
                               FontSize="28"
                               LetterSpacing="4"
                               FontWeight="Light"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="LIVE_READINESS"
                                   FontSize="12"
                                   FontFamily="Consolas"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentCyanBrush}"
                                   LetterSpacing="1"/>
                        <TextBlock Text="//"
                                   FontSize="12"
                                   FontFamily="Consolas"
                                   Foreground="{DynamicResource TextMutedBrush}"/>
                        <TextBlock Text="{Binding CoreReadinessStatus}"
                                   FontSize="12"
                                   FontFamily="Consolas"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   LetterSpacing="1"/>
                    </StackPanel>
                </StackPanel>

                <Button Grid.Column="1"
                        Command="{Binding RefreshCommand}"
                        MinWidth="112"
                        Height="36"
                        Padding="14,0"
                        CornerRadius="6"
                        Background="{DynamicResource CardBgHoverBrush}"
                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                        BorderThickness="1"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Path Data="M12,4V1L8,5L12,9V6C15.31,6 18,8.69 18,12C18,13.01 17.75,13.96 17.3,14.8L18.76,16.26C19.54,15.03 20,13.57 20,12C20,7.58 16.42,4 12,4M6.7,9.2L5.24,7.74C4.46,8.97 4,10.43 4,12C4,16.42 7.58,20 12,20V23L16,19L12,15V18C8.69,18 6,15.31 6,12C6,10.99 6.25,10.04 6.7,9.2Z"
                              Width="14"
                              Height="14"
                              Stretch="Uniform"
                              Fill="{DynamicResource AccentCyanBrush}"
                              VerticalAlignment="Center"/>
                        <TextBlock Text="Refresh"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>

            <ItemsControl Grid.Row="1" ItemsSource="{Binding SummaryCards}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="4"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:RuntimeDiagnosticItemViewModel">
                        <Border Classes="ReadinessCard"
                                Classes.Ready="{Binding IsReady}"
                                Classes.Warning="{Binding IsWarning}"
                                Classes.Blocked="{Binding IsBlocked}"
                                Margin="0,0,12,0">
                            <Grid RowDefinitions="Auto, Auto, *" RowSpacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Ellipse Classes="StatusDot ReadyDot" IsVisible="{Binding IsReady}"/>
                                    <Ellipse Classes="StatusDot WarningDot" IsVisible="{Binding IsWarning}"/>
                                    <Ellipse Classes="StatusDot BlockedDot" IsVisible="{Binding IsBlocked}"/>
                                    <Ellipse Classes="StatusDot" Fill="{DynamicResource TextMutedBrush}" IsVisible="{Binding IsNeutral}"/>
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>
                                <TextBlock Grid.Row="1"
                                           Text="{Binding Value}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="2"
                                           Text="{Binding Detail}"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           TextWrapping="Wrap"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Grid.Row="2"
                    Classes="DiagnosticPanel"
                    IsVisible="{Binding HasBlockingItems}">
                <StackPanel Spacing="10">
                    <TextBlock Text="BLOCKING_ITEMS"
                               FontSize="12"
                               FontFamily="Consolas"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentErrorBrush}"
                               LetterSpacing="1"/>
                    <ItemsControl ItemsSource="{Binding BlockingItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,4"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Grid Grid.Row="3"
                  ColumnDefinitions="*, *"
                  RowDefinitions="Auto, Auto"
                  ColumnSpacing="16"
                  RowSpacing="16">
                <Border Grid.Row="0" Grid.Column="0" Classes="DiagnosticPanel">
                    <StackPanel Spacing="12">
                        <TextBlock Text="AI RUNTIME"
                                   FontSize="12"
                                   FontFamily="Consolas"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   LetterSpacing="2"/>
                        <ItemsControl ItemsSource="{Binding AiRuntimeItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:RuntimeDiagnosticItemViewModel">
                                    <Border Classes="DiagnosticRow"
                                            Classes.Ready="{Binding IsReady}"
                                            Classes.Warning="{Binding IsWarning}"
                                            Classes.Blocked="{Binding IsBlocked}">
                                        <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="10">
                                            <Ellipse Grid.Column="0" Classes="StatusDot ReadyDot" IsVisible="{Binding IsReady}"/>
                                            <Ellipse Grid.Column="0" Classes="StatusDot WarningDot" IsVisible="{Binding IsWarning}"/>
                                            <Ellipse Grid.Column="0" Classes="StatusDot BlockedDot" IsVisible="{Binding IsBlocked}"/>
                                            <StackPanel Grid.Column="1" Spacing="3">
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{Binding Detail}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Value}"
                                                       FontSize="12"
                                                       FontFamily="Consolas"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap"
                                                       MaxWidth="190"
                                                       TextAlignment="Right"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Grid.Row="0" Grid.Column="1" Classes="DiagnosticPanel">
                    <StackPanel Spacing="12">
                        <TextBlock Text="INTEGRATIONS"
                                   FontSize="12"
                                   FontFamily="Consolas"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   LetterSpacing="2"/>
                        <ItemsControl ItemsSource="{Binding IntegrationItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:RuntimeDiagnosticItemViewModel">
                                    <Border Classes="DiagnosticRow"
                                            Classes.Ready="{Binding IsReady}"
                                            Classes.Warning="{Binding IsWarning}">
                                        <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="10">
                                            <Ellipse Grid.Column="0" Classes="StatusDot ReadyDot" IsVisible="{Binding IsReady}"/>
                                            <Ellipse Grid.Column="0" Classes="StatusDot WarningDot" IsVisible="{Binding IsWarning}"/>
                                            <StackPanel Grid.Column="1" Spacing="3">
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{Binding Detail}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Value}"
                                                       FontSize="12"
                                                       FontFamily="Consolas"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextAlignment="Right"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.ColumnSpan="2" Classes="DiagnosticPanel">
                    <Grid RowDefinitions="Auto, Auto" RowSpacing="12">
                        <Grid ColumnDefinitions="*, Auto">
                            <TextBlock Text="LOCAL RUNTIME"
                                       FontSize="12"
                                       FontFamily="Consolas"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       LetterSpacing="2"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding LastRefreshText}"
                                       FontSize="11"
                                       FontFamily="Consolas"
                                       Foreground="{DynamicResource TextMutedBrush}"/>
                        </Grid>

                        <ItemsControl Grid.Row="1" ItemsSource="{Binding RuntimeItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:RuntimeDiagnosticItemViewModel">
                                    <Border Classes="DiagnosticRow"
                                            Classes.Ready="{Binding IsReady}"
                                            Classes.Warning="{Binding IsWarning}"
                                            Classes.Blocked="{Binding IsBlocked}">
                                        <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="10">
                                            <Ellipse Grid.Column="0" Classes="StatusDot ReadyDot" IsVisible="{Binding IsReady}"/>
                                            <Ellipse Grid.Column="0" Classes="StatusDot WarningDot" IsVisible="{Binding IsWarning}"/>
                                            <Ellipse Grid.Column="0" Classes="StatusDot BlockedDot" IsVisible="{Binding IsBlocked}"/>
                                            <StackPanel Grid.Column="1" Spacing="3">
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{Binding Detail}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Value}"
                                                       FontSize="12"
                                                       FontFamily="Consolas"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextAlignment="Right"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
