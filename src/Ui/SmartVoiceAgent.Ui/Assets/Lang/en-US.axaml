<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- General -->
    <x:String x:Key="Lang.AppName">Kam</x:String>
    <x:String x:Key="Lang.AppDesc">Cross-platform AI workstation assistant with modular skills</x:String>
    
    <!-- Coordinator -->
    <x:String x:Key="Lang.Coordinator.Title">COMMAND CENTER</x:String>
    <x:String x:Key="Lang.Coordinator.Subtitle">AGENT WORKSPACE READY</x:String>
    <x:String x:Key="Lang.Coordinator.Research">CODING</x:String>
    <x:String x:Key="Lang.Coordinator.Analyzer">VISION</x:String>
    <x:String x:Key="Lang.Coordinator.Tasks">TASKS</x:String>
    
    <!-- Settings -->
    <x:String x:Key="Lang.Settings.Title">Settings</x:String>
    <x:String x:Key="Lang.Settings.Subtitle">Manage your agent workspace and preferences.</x:String>

    <x:String x:Key="Lang.Settings.General">GENERAL</x:String>
    <x:String x:Key="Lang.Settings.Appearance">APPEARANCE</x:String>
    <x:String x:Key="Lang.Settings.ThemeMode">Theme Mode</x:String>
    <x:String x:Key="Lang.Settings.ThemeDesc">Choose between light and dark theme</x:String>
    <x:String x:Key="Lang.Settings.Language">Language</x:String>
    <x:String x:Key="Lang.Settings.LanguageDesc">Select interface language</x:String>

    <x:String x:Key="Lang.Settings.Startup">Startup Behavior</x:String>
    <x:String x:Key="Lang.Settings.StartupDesc">Start the agent workspace when the system boots</x:String>
    <x:String x:Key="Lang.Settings.Security">Security Level</x:String>
    <x:String x:Key="Lang.Settings.SecurityDesc">Current mode: Passive Monitoring</x:String>
    <x:String x:Key="Lang.Settings.Change">CHANGE</x:String>

    <x:String x:Key="Lang.Settings.Interface">INTERFACE</x:String>
    <x:String x:Key="Lang.Settings.ReducedMotion">Reduced Motion</x:String>
    <x:String x:Key="Lang.Settings.ReducedMotionDesc">Disable advanced particle effects</x:String>

    <x:String x:Key="Lang.Settings.System">SYSTEM</x:String>
    <x:String x:Key="Lang.Settings.KernelVersion">Runtime Version</x:String>
    <x:String x:Key="Lang.Settings.KernelVersionVal">v1.0.0 // Agent Workspace Ready</x:String>

    <x:String x:Key="Lang.Settings.About">ABOUT</x:String>
    
    <!-- Plugins -->
    <x:String x:Key="Lang.Plugins.Title">PLUGINS</x:String>
    <x:String x:Key="Lang.Plugins.Subtitle">SKILL MANAGER // EXTENSIBLE WORKSPACE</x:String>
    
</ResourceDictionary>
