<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- General -->
    <x:String x:Key="Lang.AppName">Kam</x:String>
    <x:String x:Key="Lang.AppDesc">Système d'agent vocal avancé alimenté par l'IA avec une architecture modulaire</x:String>
    
    <!-- Coordinator -->
    <x:String x:Key="Lang.Coordinator.Title">CENTRE DE COMMANDE</x:String>
    <x:String x:Key="Lang.Coordinator.Subtitle">ESPACE AGENT PRET</x:String>
    <x:String x:Key="Lang.Coordinator.Research">CODING</x:String>
    <x:String x:Key="Lang.Coordinator.Analyzer">VISION</x:String>
    <x:String x:Key="Lang.Coordinator.Tasks">TÂCHES</x:String>
    
    <!-- Settings -->
    <x:String x:Key="Lang.Settings.Title">Paramètres</x:String>
    <x:String x:Key="Lang.Settings.Subtitle">Gerez l'espace agent et vos preferences.</x:String>

    <x:String x:Key="Lang.Settings.General">GÉNÉRAL</x:String>
    <x:String x:Key="Lang.Settings.Appearance">APPARENCE</x:String>
    <x:String x:Key="Lang.Settings.ThemeMode">Mode Thème</x:String>
    <x:String x:Key="Lang.Settings.ThemeDesc">Choisir entre le thème clair et sombre</x:String>
    <x:String x:Key="Lang.Settings.Language">Langue</x:String>
    <x:String x:Key="Lang.Settings.LanguageDesc">Sélectionner la langue de l'interface</x:String>

    <x:String x:Key="Lang.Settings.Startup">Comportement au démarrage</x:String>
    <x:String x:Key="Lang.Settings.StartupDesc">Demarrer l'espace agent au lancement du systeme</x:String>
    <x:String x:Key="Lang.Settings.Security">Niveau de sécurité</x:String>
    <x:String x:Key="Lang.Settings.SecurityDesc">Mode actuel: Surveillance passive</x:String>
    <x:String x:Key="Lang.Settings.Change">MODIFIER</x:String>

    <x:String x:Key="Lang.Settings.Interface">INTERFACE</x:String>
    <x:String x:Key="Lang.Settings.ReducedMotion">Mouvement réduit</x:String>
    <x:String x:Key="Lang.Settings.ReducedMotionDesc">Désactiver les effets de particules avancés</x:String>

    <x:String x:Key="Lang.Settings.System">SYSTÈME</x:String>
    <x:String x:Key="Lang.Settings.KernelVersion">Version Runtime</x:String>
    <x:String x:Key="Lang.Settings.KernelVersionVal">v1.0.0 // Espace Agent Pret</x:String>

    <x:String x:Key="Lang.Settings.About">À PROPOS</x:String>
    
    <!-- Plugins -->
    <x:String x:Key="Lang.Plugins.Title">PLUGINS</x:String>
    <x:String x:Key="Lang.Plugins.Subtitle">GESTIONNAIRE D'EXTENSIONS // SYSTÈME MODULAIRE</x:String>
    
</ResourceDictionary>
